// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  password String
  name     String
  role     String @default("ADMIN")
}

model Product {
  id          String   @id @default(uuid())
  name        String
  category    String
  price       Float
  stock       Int
  description String?
  createdAt   DateTime @default(now())
}
